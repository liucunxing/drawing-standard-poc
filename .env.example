# ============================================================
# drawing-poc 环境变量配置（复制为 .env 后修改）
# cp .env.example .env
# ============================================================

# ── 服务器信息 ──────────────────────────────────
SERVER_IP=10.150.18.21
BACKEND_PORT=8000
FRONTEND_PORT=8501

# ── MySQL 数据库（现有，不需改动）────────────────
MYSQL_HOST=10.150.18.21
MYSQL_PORT=31002
MYSQL_DB=drawing-poc
MYSQL_USER=root
MYSQL_PASSWORD=smartvision

# ── PaddlePaddle 模型目录（容器内路径，勿改）────
PADDLE_MODELS_ROOT=/app/models/paddle

# ── 后端临时文件目录（容器内路径，勿改）────────
BACKEND_TMP_DIR=/app/project/drawing-standard-poc/backend/tmp

# ── uvicorn 配置 ────────────────────────────────
UVICORN_RELOAD=false
UVICORN_PORT=8000

# ── 日志目录（容器内路径，勿改）────────────────
LOG_DIR=/app/logs
